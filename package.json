{
  "name": "nextcloud-rag-chat",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @nextcloud-rag/api\" \"npm run dev -w @nextcloud-rag/web\"",
    "dev:api": "npm run dev -w @nextcloud-rag/api",
    "dev:web": "npm run dev -w @nextcloud-rag/web",
    "build": "npm run build -w @nextcloud-rag/shared && npm run build -w @nextcloud-rag/api && npm run build -w @nextcloud-rag/web",
    "build:api": "npm run build -w @nextcloud-rag/api",
    "build:web": "npm run build -w @nextcloud-rag/web",
    "build:shared": "npm run build -w @nextcloud-rag/shared",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d --build",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "nc:init": "bash infra/init-nextcloud.sh",
    "db:migrate": "npm run migrate -w @nextcloud-rag/api",
    "db:studio": "npm run studio -w @nextcloud-rag/api",
    "test:integration": "bash infra/test-integration.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
